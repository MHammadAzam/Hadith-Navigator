{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "One of the Sihah-e-Sitta Hadith books",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "nameUrdu": { "type": "string" },
        "nameArabic": { "type": "string" },
        "description": { "type": "string" },
        "hadithCount": { "type": "number" },
        "chapterCount": { "type": "number" },
        "color": { "type": "string", "description": "Primary theme color for the book" }
      },
      "required": ["id", "name"]
    },
    "Chapter": {
      "title": "Chapter",
      "description": "A Kitab (Book/Chapter) within a Hadith collection",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bookId": { "type": "string" },
        "number": { "type": "number" },
        "name": { "type": "string" },
        "nameArabic": { "type": "string" },
        "nameUrdu": { "type": "string" },
        "hadithRange": { "type": "string" }
      },
      "required": ["id", "bookId", "name"]
    },
    "Hadith": {
      "title": "Hadith",
      "description": "A single prophetic tradition",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bookId": { "type": "string" },
        "chapterId": { "type": "string" },
        "hadithNumber": { "type": "string" },
        "arabicText": { "type": "string" },
        "englishTranslation": { "type": "string" },
        "urduTranslation": { "type": "string" },
        "reference": { "type": "string" },
        "tags": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "authenticity": { "type": "string", "enum": ["Sahih", "Hasan", "Da'if", "Maudu"] }
      },
      "required": ["id", "bookId", "arabicText"]
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "A user's saved hadith",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hadithId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "cachedHadith": { "type": "object", "description": "Optional snapshot of the hadith for offline access" }
      },
      "required": ["id", "hadithId", "userId"]
    }
  },
  "firestore": {
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Metadata for the 6 primary hadith books"
    },
    "/books/{bookId}/chapters/{chapterId}": {
      "schema": "Chapter",
      "description": "Chapters (Kitabs) for a specific book"
    },
    "/hadiths/{hadithId}": {
      "schema": "Hadith",
      "description": "Individual Hadith records"
    },
    "/users/{userId}/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User specific bookmarks"
    }
  }
}
