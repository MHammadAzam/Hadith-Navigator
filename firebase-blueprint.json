{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account settings and basic profile info.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "language": { "type": "string", "enum": ["English", "Urdu", "Arabic"] },
        "fontSize": { "type": "number" },
        "streak": { "type": "number" },
        "lastActive": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email"]
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "A saved Ayah or Hadith.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "itemId": { "type": "string" },
        "itemType": { "type": "string", "enum": ["hadith", "verse"] },
        "itemData": { "type": "object" },
        "savedAt": { "type": "number" },
        "collectionId": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["userId", "itemId", "itemType", "itemData", "savedAt"]
    },
    "UserCollection": {
      "title": "User Collection",
      "description": "A custom list for organizing bookmarks.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "number" },
        "itemCount": { "type": "number" }
      },
      "required": ["userId", "name", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User settings and profile."
    },
    "/users/{userId}/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User's saved items."
    },
    "/users/{userId}/collections/{collectionId}": {
      "schema": "UserCollection",
      "description": "User's custom bookmark collections."
    }
  }
}
