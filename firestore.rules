rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validations
    function isValidBookmark(data) {
      return data.keys().hasAll(['id', 'hadithId', 'userId', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.userId == request.auth.uid
        && data.hadithId is string
        && (data.createdAt is timestamp || data.createdAt is string)
        && (!data.keys().contains('notes') || (data.notes is string && data.notes.size() <= 2000));
    }

    // Collection: Books (Sihah-e-Sitta)
    match /books/{bookId} {
      allow read: if true; // Publicly readable
      allow write: if false; // System only
      
      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Collection: Hadiths
    match /hadiths/{hadithId} {
      allow read: if true;
      allow write: if false;
    }

    // Collection: User Bookmarks (Nested under users)
    match /users/{userId}/bookmarks/{bookmarkId} {
      allow read, write: if isOwner(userId);
      
      // Additional validation on create
      allow create: if isOwner(userId) && isValidId(bookmarkId) && isValidBookmark(incoming());
    }
    
    // Fallback for flat bookmarks if used
    match /bookmarks/{bookmarkId} {
      allow read: if isVerified() && resource.data.userId == request.auth.uid;
      allow write: if isVerified() && (incoming().userId == request.auth.uid || existing().userId == request.auth.uid);
    }
  }
}
