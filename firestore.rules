rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Bookmark validation
    function isValidBookmark(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'arabic', 'english', 'urdu', 'source', 'timestamp'])
        && data.id is string && data.id.size() <= 256
        && data.userId == request.auth.uid
        && data.type in ['Quran', 'Hadith']
        && data.arabic is string && data.arabic.size() <= 5000
        && data.english is string && data.english.size() <= 5000
        && data.urdu is string && data.urdu.size() <= 5000
        && data.source is string && data.source.size() <= 512
        && (data.timestamp is timestamp || data.timestamp is int || data.timestamp is float)
        // Optional fields
        && (!data.keys().contains('notes') || (data.notes is string && data.notes.size() <= 2000))
        && (!data.keys().contains('explanation') || data.explanation is map)
        && (!data.keys().contains('lifeApplication') || data.lifeApplication is map)
        && (!data.keys().contains('reflection') || data.reflection is map)
        && (!data.keys().contains('actionSteps') || data.actionSteps is list);
    }

    match /bookmarks/{bookmarkId} {
      allow get: if isVerified() && isOwner(existing().userId);
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      
      allow create: if isVerified() 
        && isValidId(bookmarkId)
        && incoming().id == bookmarkId
        && isValidBookmark(incoming())
        && (incoming().timestamp == request.time || incoming().timestamp is int); 

      allow update: if isVerified()
        && isValidBookmark(incoming())
        && incoming().userId == existing().userId
        && incoming().id == existing().id // Immutable fields
        && (
          // Allow specific updates OR metadata re-sync
          incoming().diff(existing()).affectedKeys().hasOnly(['notes'])
          || 
          incoming().diff(existing()).affectedKeys().hasAny(['explanation', 'lifeApplication', 'reflection', 'actionSteps', 'timestamp'])
        );

      allow delete: if isVerified() && isOwner(existing().userId);
    }
  }
}
